# Copy to .env and fill in.
# .env is gitignored.

# Required for live Claude integration. Without this, the system runs in mock mode.
ANTHROPIC_API_KEY=

# JWT — change in any non-local environment.
JWT_SECRET=dev-secret-change-me

# Postgres connection string. docker-compose sets this automatically;
# DigitalOcean Managed DB injects it via ${cfo-db.DATABASE_URL}.
DATABASE_URL=postgresql://cfo:cfo@localhost:5432/cfo

# Model identifiers (override only if you need to pin to specific snapshots).
MODEL_CONDUCTOR=claude-opus-4-5
MODEL_SPECIALIST=claude-sonnet-4-5
MODEL_HAIKU=claude-haiku-4-5
